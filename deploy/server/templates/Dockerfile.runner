ARG BASE_IMAGE=ghcr.io/anomalyco/opencode:latest
FROM ${BASE_IMAGE}

COPY --chmod=0755 run_opencode_task.sh /usr/local/bin/run_opencode_task.sh
COPY --chmod=0755 run_openclaw_task.sh /usr/local/bin/run_openclaw_task.sh
COPY --chmod=0755 run_claudecode_task.sh /usr/local/bin/run_claudecode_task.sh
COPY --chmod=0755 run_mock_task.sh /usr/local/bin/run_mock_task.sh

USER root

# Run as non-root user inside the image.
RUN grep -q '^cloudclaw:' /etc/group || addgroup -S cloudclaw && \
    grep -q '^cloudclaw:' /etc/passwd || adduser -S -D -h /home/cloudclaw -G cloudclaw cloudclaw && \
    mkdir -p /home/cloudclaw /tmp/cloudclaw /workspace && \
    chown -R cloudclaw:cloudclaw /home/cloudclaw /tmp/cloudclaw /workspace

ENV HOME=/home/cloudclaw
USER cloudclaw
